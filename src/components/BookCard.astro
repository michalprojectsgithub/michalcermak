---
// src/components/BookCard.astro
interface Props {
  title: string;
  author: string;
  status: 'read' | 'reading' | 'want-to-read';
  note?: string;
}

const { title, author, status, note } = Astro.props;

const statusLabel: Record<string, string> = {
  read:          'read',
  reading:       'reading',
  'want-to-read': 'want to read',
};

const statusStyles: Record<string, string> = {
  read:          'text-muted border-border',
  reading:       'text-green-400 border-green-900',
  'want-to-read': 'text-muted border-border',
};
---

<article class="border border-border rounded bg-surface p-4 flex flex-col gap-2">
  <div class="flex items-start justify-between gap-2">
    <h3 class="font-serif text-heading text-base leading-snug">{title}</h3>
    <span class:list={['font-mono text-xs border px-2 py-0.5 rounded shrink-0', statusStyles[status]]}>
      {statusLabel[status]}
    </span>
  </div>
  <span class="font-mono text-xs text-muted">{author}</span>
  {note && <p class="font-serif italic text-text text-sm leading-relaxed mt-1">{note}</p>}
</article>
